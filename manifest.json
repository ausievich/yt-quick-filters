{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "YouTrack Quick Filters",
  "version": "3.2.2",
  "description": "Add quick filter buttons to YouTrack Agile Boards. Create filters via a modal.",
  "icons": { "128": "icons/logo_128.png" },
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": ["https://openrouter.ai/*"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "side_panel": {
    "default_path": "public/sidepanel.html"
  },
  "options_page": "public/options.html",
  "action": {
    "default_title": "YouTrack Quick Filters — открыть AI-панель",
    "default_icon": {
      "128": "icons/logo_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "css": ["dist/content.css"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
